# Copy this file to .env and update values for your local machine.

PGHOST=localhost
PGPORT=55432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=ledger_event_store

# Preferred connection string used by scripts and app code.
DATABASE_URL=postgresql://postgres:postgres@localhost:55432/ledger_event_store

# API runtime configuration
API_HOST=127.0.0.1
API_PORT=8000
API_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://0.0.0.0:5173,http://[::1]:5173
# If dashboard runs from LAN IP (for example http://10.x.x.x:5173),
# add it here too:
# API_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://10.69.158.161:5173
API_APPLY_SCHEMA_ON_START=true
# LEDGER_API_KEY=replace-me

# Outbox delivery configuration
OUTBOX_PUBLISHER=sink
# If using Docker Kafka from `make kafka-start`, use:
# KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# KAFKA_CLIENT_ID=ledger-outbox-relay
# KAFKA_COMPRESSION_TYPE=gzip
# Optional when relay runs inside Docker Compose:
# OUTBOX_RELAY_DATABASE_URL=postgresql://postgres:postgres@host.docker.internal:55432/ledger_event_store

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# JWT auth settings (required for production)
JWT_SECRET=replace-with-long-random-secret
JWT_ISSUER=ledger-api
JWT_TTL_MINUTES=120
SEED_DEMO_USERS=true
LEDGER_ANALYST_ONE_USERNAME=melat
LEDGER_ANALYST_ONE_PASSWORD=melat@123
LEDGER_ANALYST_TWO_USERNAME=kedir
LEDGER_ANALYST_TWO_PASSWORD=kedir@123
LEDGER_ADMIN_USERNAME=nurye
LEDGER_ADMIN_PASSWORD=nurye@123
